#!/bin/bash
set -e
set -o pipefail

export ADD_PGTAP_EXTENSION=${ADD_PGTAP_EXTENSION:=false}

psql -d postgres -c "CREATE DATABASE $MINERVA_DB_NAME;"

if [ ${ADD_PGTAP_EXTENSION} = true ]; then
    psql -c "CREATE EXTENSION pgtap;"
fi

echo '#####################################'
echo 'Creating Minerva database...'
find $WORKSPACE/src -name '*.sql' | sort | while read filepath
do
    echo '#####################################'
    echo $filepath
    echo '#####################################'
    psql -v ON_ERROR_STOP=1 -f $filepath
done

if [ -d "$WORKSPACE/custom" ]; then
    echo '#####################################'
    echo 'Loading custom scripts...'
    find $WORKSPACE/custom -name '*.sql' | sort | while read filepath
    do
        echo '#####################################'
        echo $filepath
        echo '#####################################'
        psql -v ON_ERROR_STOP=1 -f $filepath
    done
fi
