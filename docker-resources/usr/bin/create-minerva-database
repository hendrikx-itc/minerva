#!/bin/bash
set -e
set -o pipefail

psql -d postgres -c "CREATE DATABASE $MINERVA_DB_NAME;"

find /db-deps/scripts/ -name '*.sql' | sort | while read filepath
do
    echo '#####################################'
    echo $filepath
    echo '#####################################'
    psql -v ON_ERROR_STOP=1 -f $filepath
done

find /minerva/src -name '*.sql' | sort | while read filepath
do
    echo '#####################################'
    echo $filepath
    echo '#####################################'
    psql -v ON_ERROR_STOP=1 -f $filepath
done

